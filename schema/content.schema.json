{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://microsoft.github.io/agent-adoption-advisor/content.schema.json",
  "title": "Agent Adoption Advisor content",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "lastReviewed", "questions", "approaches", "rules"],
  "properties": {
    "version": { "type": "string", "minLength": 1 },
    "lastReviewed": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "questions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/question" }
    },
    "approaches": {
      "type": "array",
      "minItems": 2,
      "items": { "$ref": "#/definitions/approach" }
    },
    "rules": { "$ref": "#/definitions/rules" }
  },
  "definitions": {
    "question": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "prompt", "options"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "prompt": { "type": "string", "minLength": 1 },
        "options": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "label"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "label": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "approach": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "summary", "pros", "cons", "whenNotToUse"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "pros": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "cons": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "whenNotToUse": { "type": "string", "minLength": 1 }
      }
    },
    "rules": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "weights",
        "disqualifiers",
        "requiredPrereqs",
        "strongFits",
        "strongFitBonus",
        "confidence"
      ],
      "properties": {
        "strongFitBonus": { "type": "number", "minimum": 0 },
        "weights": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["question", "option", "approach", "points"],
            "properties": {
              "question": { "type": "string", "minLength": 1 },
              "option": { "type": "string", "minLength": 1 },
              "approach": { "type": "string", "minLength": 1 },
              "points": { "type": "number" }
            }
          }
        },
        "disqualifiers": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["question", "option", "approach", "reason"],
            "properties": {
              "question": { "type": "string", "minLength": 1 },
              "option": { "type": "string", "minLength": 1 },
              "approach": { "type": "string", "minLength": 1 },
              "reason": { "type": "string", "minLength": 1 }
            }
          }
        },
        "requiredPrereqs": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["approach", "question", "option", "reason"],
            "properties": {
              "approach": { "type": "string", "minLength": 1 },
              "question": { "type": "string", "minLength": 1 },
              "option": { "type": "string", "minLength": 1 },
              "reason": { "type": "string", "minLength": 1 }
            }
          }
        },
        "strongFits": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["question", "option", "approach", "reason"],
            "properties": {
              "question": { "type": "string", "minLength": 1 },
              "option": { "type": "string", "minLength": 1 },
              "approach": { "type": "string", "minLength": 1 },
              "reason": { "type": "string", "minLength": 1 }
            }
          }
        },
        "confidence": {
          "type": "object",
          "additionalProperties": false,
          "required": ["highMargin", "mediumMargin", "minFit"],
          "properties": {
            "highMargin": { "type": "number", "minimum": 0, "maximum": 1 },
            "mediumMargin": { "type": "number", "minimum": 0, "maximum": 1 },
            "minFit": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        }
      }
    }
  }
}
